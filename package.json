{
  "name": "obsidian-widget",
  "version": "1.0.0",
  "description": "macOS menu bar app with native WidgetKit desktop widget for random Obsidian note summaries",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "build:macos-widget": "bash scripts/build-macos-widget.sh",
    "embed:widget": "bash scripts/embed-widget.sh",
    "build:all": "npm run build && npm run build:macos-widget && npm run embed:widget",
    "start": "electron-vite preview",
    "lint": "eslint . --quiet"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.1",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@vitejs/plugin-react": "^4.5.1",
    "electron": "^36.4.0",
    "electron-vite": "^3.1.0",
    "eslint": "^9.28.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^16.2.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.33.1",
    "vite": "^6.3.5"
  }
}
